<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Genie.App.Views.ConfirmDialog"
        Title="Confirm"
        Width="420" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

  <Grid RowDefinitions="*,Auto" Margin="20,16,20,16">

    <!-- Message: free-text, wraps to width so longer prompts stay readable. -->
    <TextBlock Grid.Row="0"
               x:Name="MessageText"
               TextWrapping="Wrap"
               FontSize="13"
               VerticalAlignment="Center"/>

    <!-- Yes is always the default action (Enter). The Esc / close-box
         role belongs to the No button in 2-button mode and the Cancel
         button in 3-button mode; the constructor toggles IsCancel
         accordingly. Cancel is hidden in 2-button mode. -->
    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,16,0,0">
      <Button x:Name="YesButton"
              Content="_Yes"
              MinWidth="88"
              IsDefault="True"
              Click="OnYesClick"/>
      <Button x:Name="NoButton"
              Content="_No"
              MinWidth="88"
              Click="OnNoClick"/>
      <Button x:Name="CancelButton"
              Content="_Cancel"
              MinWidth="88"
              IsVisible="False"
              Click="OnCancelClick"/>
    </StackPanel>

  </Grid>
</Window>
