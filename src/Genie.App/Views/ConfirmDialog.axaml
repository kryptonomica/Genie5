<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Genie.App.Views.ConfirmDialog"
        Title="Confirm"
        Width="420" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

  <Grid RowDefinitions="*,Auto" Margin="20,16,20,16">

    <!-- Message: free-text, wraps to width so longer prompts stay readable. -->
    <TextBlock Grid.Row="0"
               x:Name="MessageText"
               TextWrapping="Wrap"
               FontSize="13"
               VerticalAlignment="Center"/>

    <!-- Yes (default, fires on Enter) / No (cancel, fires on Esc). The
         "_Y" / "_N" mnemonics give Alt+Y / Alt+N keyboard access. -->
    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,16,0,0">
      <Button Content="_Yes"
              MinWidth="88"
              IsDefault="True"
              Click="OnYesClick"/>
      <Button Content="_No"
              MinWidth="88"
              IsCancel="True"
              Click="OnNoClick"/>
    </StackPanel>

  </Grid>
</Window>
