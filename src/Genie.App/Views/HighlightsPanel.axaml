<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:Genie.App.Views"
             x:Class="Genie.App.Views.HighlightsPanel">

  <TabControl>

    <TabItem Header="Strings">
      <views:HighlightStringsPanel Name="StringsPanelCtrl"/>
    </TabItem>

    <TabItem Header="Names">
      <views:NamesPanel Name="NamesPanelCtrl"/>
    </TabItem>

    <TabItem Header="Presets">
      <views:PresetsPanel Name="PresetsPanelCtrl"/>
    </TabItem>

  </TabControl>
</UserControl>
