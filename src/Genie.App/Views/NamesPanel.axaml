<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Genie.App.Views.NamesPanel">

  <Grid RowDefinitions="Auto,*">

    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="4,4,4,0">
      <Button Content="Refresh"  Click="OnRefresh" />
      <Button Content="Add"      Click="OnAdd" />
      <Button Content="Remove"   Click="OnRemove" />
      <Button Content="Import…"  Click="OnImport" />
    </StackPanel>

    <!-- Top: name list. Bottom: editor pane. -->
    <Grid Grid.Row="1" RowDefinitions="*,Auto" Margin="4">
      <DataGrid Name="ItemsList"
                Grid.Row="0"
                Margin="0,0,0,4"
                IsReadOnly="True"
                SelectionMode="Single"
                CanUserSortColumns="True"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                x:CompileBindings="False"
                SelectionChanged="OnSelectionChanged">
        <DataGrid.Columns>
          <!-- Name cell renders in the rule's own fg/bg so the row previews
               what each player-name highlight will look like in-game. -->
          <DataGridTemplateColumn Header="Name" Width="*">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border Background="{Binding NameBackground}" Padding="6,1">
                  <TextBlock Text="{Binding Name}"
                             Foreground="{Binding NameForeground}"
                             VerticalAlignment="Center"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Fg" Binding="{Binding ForegroundColor}" Width="Auto" />
          <DataGridTextColumn Header="Bg" Binding="{Binding BackgroundColor}" Width="Auto" />
        </DataGrid.Columns>
      </DataGrid>

      <Grid Grid.Row="1"
            ColumnDefinitions="Auto,*,Auto,*"
            RowDefinitions="Auto,Auto,Auto,Auto"
            Margin="0,4,0,0">

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,8,4"/>
        <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                   Name="NameBox" Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Foreground:" VerticalAlignment="Center" Margin="0,0,8,4"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="0,0,8,4">
          <ColorPicker Name="FgColorPicker" IsAlphaEnabled="False"/>
          <CheckBox    Name="FgDefaultCheck" Content="Use default" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock Grid.Row="1" Grid.Column="2" Text="Background:" VerticalAlignment="Center" Margin="0,0,8,4"/>
        <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
          <ColorPicker Name="BgColorPicker" IsAlphaEnabled="False"/>
          <CheckBox    Name="BgNoneCheck" Content="None" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                    Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
          <Button Content="Save"  Click="OnSaveRule"/>
          <Button Content="Clear" Click="OnClear"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                   Name="StatusText" Margin="0,6,0,0"
                   Foreground="Gray" FontStyle="Italic"/>
      </Grid>
    </Grid>

  </Grid>
</UserControl>
