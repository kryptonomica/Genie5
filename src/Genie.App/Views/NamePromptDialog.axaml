<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Genie.App.Views.NamePromptDialog"
        Title="Name"
        Width="380" Height="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto" Margin="16">

    <TextBlock x:Name="PromptText" Grid.Row="0"
               Text="Enter a name:"
               Foreground="#cdd" FontSize="12"
               Margin="0,0,0,8"/>

    <TextBox x:Name="NameInput" Grid.Row="1"
             Text=""
             FontSize="12"
             VerticalAlignment="Top"/>

    <StackPanel Grid.Row="2" Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8" Margin="0,16,0,0">
      <Button x:Name="CancelButton" Content="Cancel" Width="80"
              Click="OnCancel"/>
      <Button x:Name="OkButton" Content="OK" Width="80"
              IsDefault="True" Click="OnOk"/>
    </StackPanel>

  </Grid>
</Window>
